# BenAI Skills - API Keys Configuration
# Copy this file to .env in your project directory and fill in your API keys

# ============================================================================
# Marketing Plugin
# ============================================================================

# GEMINI_API_KEY - Required for /infographic skill
# Get your key: https://aistudio.google.com/apikey
# Used by: AI-generated infographics via nano-banana MCP
GEMINI_API_KEY=

# APIFY_TOKEN - Required for /seo-audit and /programmatic-seo skills
# Get your key: https://console.apify.com/account/integrations
# Used by: Web scraping, SEO audits, data extraction
APIFY_TOKEN=

# NANO_BANANA_OUTPUT_DIR - Optional, defaults to ~/Desktop/nano-banana-output
# Directory where generated infographic images will be saved
NANO_BANANA_OUTPUT_DIR=./output/infographics

# ============================================================================
# Creative Plugin
# ============================================================================

# GEMINI_API_KEY - Required for /infographic skill
# (Same key as marketing - fill in above)

# ============================================================================
# Operations Plugin
# ============================================================================

# N8N_API_URL - Required for /n8n skill
# Your n8n instance URL (e.g., https://your-instance.app.n8n.cloud)
N8N_API_URL=

# N8N_API_KEY - Required for /n8n skill
# Get from: n8n Settings → API → Create API Key
N8N_API_KEY=

# N8N_CREDENTIALS_TEMPLATE_URL - Required for /n8n skill
# URL to your n8n credentials template workflow
N8N_CREDENTIALS_TEMPLATE_URL=
