{
  "name": "Personal OS",
  "description": "Personal OS \u2014 Turn any folder into a personal AI assistant with persistent memory, task management, meeting intelligence, daily routines, and multiple output styles. Includes session management, a teaching loop that learns from corrections, and goal tracking with Obsidian integration.",
  "version": "1.0.0",
  "author": {
    "name": "BenAI"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/load-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-memory-stop.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
